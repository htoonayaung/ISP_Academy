# Ignore everything in this mixed workspace by default.
*

# Track only the AI-Powered ISP Academy MVP project files.
!backend/
!backend/**
!deployments/
!deployments/**
!docs/
!docs/**
!frontend/
!frontend/**
!scripts/
!scripts/**
!backups/
!backups/.gitkeep
!README.md
!.gitignore

# Python/cache/build artifacts.
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Local environment files and secrets.
*.env
backend.env
deployments/env/backend.env

# Backup outputs.
backups/*.sql
backups/*.dump
backups/*.tar.gz
!backups/.gitkeep

# Runtime lab files.
lab-storage/
lab-storage/**

# OS/editor noise.
.DS_Store
Thumbs.db
.vscode/
.idea/
