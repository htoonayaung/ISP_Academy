APP_NAME=AI-Powered ISP Academy MVP
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=http://10.0.44.2:3000,http://10.0.44.2:5173,http://localhost:3000,http://localhost:5173

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=isp_academy
POSTGRES_PASSWORD=change_this_development_password
POSTGRES_DB=isp_academy

JWT_SECRET_KEY=change_this_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change_this_initial_admin_password
INITIAL_ADMIN_FULL_NAME=Initial Admin

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

LAB_ROOT=/opt/isp-academy/lab-storage
CONTAINERLAB_BIN=/usr/bin/containerlab
CONTAINERLAB_COMMAND_TIMEOUT_SECONDS=120
LAB_EVENT_OUTPUT_LIMIT=12000
